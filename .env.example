# Variaveis publicas do app (EXPO_PUBLIC_*). Sao empacotadas no binario e devem
# ser tratadas como PUBLICAS. NUNCA coloque aqui service role key ou segredos de
# backend. Copie para .env local (git-ignored) para rodar em Expo Go / dev.

# URL do backend proprio (HTTPS obrigatorio em builds EAS).
EXPO_PUBLIC_API_BASE_URL=https://SEU_BACKEND

# Projeto Supabase (usado apenas para Auth com a anon/publishable key).
EXPO_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co

# Anon/publishable key publica do Supabase (NAO e a service role).
# Em builds EAS ela deve vir de variavel de ambiente do EAS, nao do eas.json.
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx
